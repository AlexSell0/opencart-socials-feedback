{{ header }}
{{ column_left }}
<div id="content">
    <div class="page-header">
        <div class="container-fluid">
            <div class="pull-right">
                <button type="submit" form="form-module" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
                <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a>
            </div>
            <h1>{{ heading_title }}</h1>
            <br />
            <ul class="breadcrumb">
                {% for breadcrumb in breadcrumbs %}
                    <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
                {% endfor %}
            </ul>
        </div>
    </div>
    <div class="container-fluid">
        {% if error_warning %}
            <div class="alert alert-danger"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
                <button type="button" class="close" data-dismiss="alert">&times;</button>
            </div>
        {% endif %}
        <div class="panel panel-default">
            <div class="panel-heading">
                <h3 class="panel-title"><i class="fa fa-pencil"></i> {{ text_edit }}</h3>
            </div>
            <div class="panel-body">
                <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-module" class="form-horizontal">
                    <ul class="nav nav-tabs">
                        <li class="active"><a href="#tab-general" data-toggle="tab">{{ tab_general }}</a></li>
                        <li><a href="#tab-help" data-toggle="tab">{{ tab_help }}</a></li>
                    </ul>
                    <div class="tab-content">
                        <div class="tab-pane active" id="tab-general">
                            <div class="form-group">
                                <label class="col-sm-2 control-label" for="input-color">{{ entry_main_color }}</label>
                                <div class="col-sm-10">
                                    <input type="color" name="module_socials_feedback_color" value="{{ color }}" placeholder="{{ entry_main_color }}" id="input-color" class="form-control" />
                                </div>
                            </div>

                            <div class="form-group">
                                <label class="col-sm-2 control-label" for="input-name">{{ entry_module_socials_feedback_links }}</label>
                                <div class="col-sm-10">
                                    <ul class="nav nav-tabs" style="margin-bottom:10px">
                                        {% for lang in languages %}
                                            <li{{ loop.first ? ' class="active"' }}><a href="#slide-lang-{{ lang.language_id }}" data-toggle="tab"><img src="language/{{ lang.code }}/{{ lang.code }}.png" title="{{ lang.name }}" /></a></li>
                                        {% endfor %}
                                    </ul>
                                    <div class="tab-content">
                                        {% for lang in languages %}
                                            {% set lang_id = lang.language_id %}

                                            <div id="slide-lang-{{ lang_id }}" class="tab-pane{{ loop.first ? ' active' : '' }}">
                                                <table id="module_socials_feedback_links_{{ lang_id }}" class="table table-striped table-bordered">
                                                    <thead>
                                                    <tr>
                                                    <th style="text-align:center;width:80px">{{ entry_visible }}</th>
                                                        <th style="text-align:center;width:120px">{{ entry_image }}</th>
                                                        <th style="text-align:center;width:150px">{{ entry_type }}</th>
                                                        <th style="text-align:center;width:120px">{{ entry_color }}</th>
                                                        <th>{{ entry_data }}</th>
                                                        <th style="text-align:center; width:90px">{{ entry_sort }}</th>
                                                        <th style="text-align:center; width:50px"></th>
                                                    </tr>
                                                    </thead>
                                                    <tbody>
                                                    {% for slide in module_socials_feedback_links[lang_id] %}
                                                        <tr class="slide-{{ lang_id }}">
                                                            <td>
                                                                <label style="font-weight:400;cursor:pointer">
                                                                    <input type="checkbox" name="module_socials_feedback_links[{{ lang_id }}][{{ loop.index0 }}][visible]" {{ slide.visible ? 'checked="checked"' : '' }} value="1" />
                                                                </label>
                                                            </td>
                                                            <td style="text-align:center">
                                                                <a href="" id="thumb-image-{{ loop.index0 }}-{{ lang_id }}" data-toggle="image" class="img-thumbnail">
                                                                    <img src="{{ slide.thumb ? slide.thumb : placeholder }}" alt="" title="" data-placeholder="{{ placeholder }}" />
                                                                </a>
                                                                <input type="hidden" name="module_socials_feedback_links[{{ lang_id }}][{{ loop.index0 }}][image]" value="{{ slide.image }}" id="input-image-{{ loop.index0 }}-{{ lang_id }}" />
                                                                {% if error is defined and error['error_image_' ~ lang_id ~ '_' ~ loop.index0] is defined %}
                                                                    <div class="text-danger">{{ error_image }}</div>
                                                                {% endif %}
                                                            </td>
                                                            <td style="text-align:center">
                                                                <select name="module_socials_feedback_links[{{ lang_id }}][{{ loop.index0 }}][type]" class="form-control">
                                                                    {% for social in socials %}
                                                                        <option value="{{ social.value }}" {{ slide.type == social.value ? 'selected' : '' }}>{{ social.name }}</option>
                                                                    {% endfor %}
                                                                </select>
                                                            </td>
                                                            <td style="text-align:center">
                                                                <input type="color"  name="module_socials_feedback_links[{{ lang_id }}][{{ loop.index0 }}][color]" value="{{ slide.color }}" class="form-control" />
                                                                {% if error is defined and error['error_color_' ~ lang_id ~ '_' ~ loop.index0] is defined %}
                                                                    <div class="text-danger">{{ error_color }}</div>
                                                                {% endif %}
                                                                <div style="margin-top: 5px;">
                                                                    <label>
                                                                        <input type="checkbox" name="module_socials_feedback_links[{{ lang_id }}][{{ loop.index0 }}][is_color]" value="1" {{ slide.is_color ? 'checked="checked"' : '' }} /> {{ entry_is_show }}
                                                                    </label>
                                                                </div>
                                                            </td>
                                                            <td>
                                                                <label class="control-label">{{ placeholder_title }}</label>
                                                                <input type="text" name="module_socials_feedback_links[{{ lang_id }}][{{ loop.index0 }}][title]" value="{{ slide.title }}" placeholder="{{ placeholder_title }}" class="form-control" />
                                                                {% if error is defined and error['error_title_' ~ lang_id ~ '_' ~ loop.index0] is defined %}
                                                                    <div class="text-danger">{{ error_title }}</div>
                                                                {% endif %}
                                                                <br />
                                                                <label class="control-label">{{ placeholder_link }}</label>
                                                                <input type="text" name="module_socials_feedback_links[{{ lang_id }}][{{ loop.index0 }}][link]" value="{{ slide.link }}" placeholder="{{ placeholder_link }}" class="form-control" />
                                                                {% if error is defined and error['error_link_' ~ lang_id ~ '_' ~ loop.index0] is defined %}
                                                                    <div class="text-danger">{{ error_link }}</div>
                                                                {% endif %}
                                                            </td>
                                                            <td style="text-align:center">
                                                                <input type="text" name="module_socials_feedback_links[{{ lang_id }}][{{ loop.index0 }}][sort]" value="{{ slide.sort ? slide.sort : 1 }}" class="form-control" style="width:50px; text-align:center" />
                                                            </td>
                                                            <td style="text-align:center">
                                                                <button type="button" onclick="$(this).parent().parent().remove();" data-toggle="tooltip" title="{{ button_remove }}" class="btn btn-danger"><i class="fa fa-minus-circle"></i></button>
                                                            </td>
                                                        </tr>
                                                    {% endfor %}
                                                    </tbody>
                                                </table>
                                                <div>
                                                    <button type="button" onclick="addSlide({{ lang_id }}, this);" class="btn btn-primary" data-original-title="{{ button_add }}"><i class="fa fa-plus-circle"></i></button>
                                                </div>
                                                <hr />
                                            </div>
                                        {% endfor %}
                                    </div>
                                </div>
                            </div>
                            <div class="form-group">
                                <label class="col-sm-2 control-label" for="input-status">{{ entry_status }}</label>
                                <div class="col-sm-10">
                                    <select name="module_socials_feedback_status" id="input-status" class="form-control">
                                        <option value="1" {{ status ? 'selected="selected"' : '' }}>{{ text_enabled }}</option>
                                        <option value="0" {{ status == 0 ? 'selected="selected"' : '' }}>{{ text_disabled }}</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="tab-pane" id="tab-help">
                            <div class="form-group">
                                <div class="col-sm-10">
                                    <p>Версия модуля 1.0.0</p>
                                    <p>Сайт автора <a href="https://github.com/AlexSell0/opencart-socials-feedback">https://github.com/AlexSell0/opencart-socials-feedback</a></p>
                                    <p>Все интересующие Вас вопросы и предложения направляйте по адресу электронной почты
                                        <a href="mailto:alexsell72@gmail.com">alexsell72@gmail.com</a> либо телеграм
                                        <a href="https://t.me/AlexS735">@AlexS735</a></p>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
<script type="text/javascript"><!--
    function addSlide(lang_id, elem) {
        const block = $(elem).parent().prev();
        const slide_id = $('.slide-' + lang_id).length;

        let html = '<tr class="slide-' + lang_id + '">';
        html += '<td style="text-align:center"><label style="font-weight:400;cursor:pointer"><input type="checkbox" name="module_socials_feedback_links[' + lang_id + '][' + slide_id + '][visible]" value="1" /> {{ entry_visible }}</label></td>';
        html += '<td style="text-align:center">';
        html += '<a href="" id="thumb-image-' + slide_id + '-' + lang_id + '" data-toggle="image" class="img-thumbnail"><img src="{{ placeholder }}" alt="" title="" data-placeholder="{{ placeholder }}" /></a>';
        html += '<input type="hidden" name="module_socials_feedback_links[' + lang_id + '][' + slide_id + '][image]" value="" id="input-image-' + slide_id + '-' + lang_id + '" />';
        html += '</td>';
        html += '<td style="text-align:center"><select name="module_socials_feedback_links[' + lang_id + '][' + slide_id + '][type]" class="form-control">';
        {% for social in socials %}
        html += '<option value="{{ social.value }}"{% if social.value == 'link' %} selected{% endif %}>{{ social.name }}</option>';
        {% endfor %}
        html += '</select></td>';
        html += '<td style="text-align:center">';
        html += '<input type="color" name="module_socials_feedback_links[' + lang_id + '][' + slide_id + '][color]" value="{{ default_color }}" class="form-control" />';
        // ADDED: checkbox is_color для динамически добавляемых строк
        html += '<div style="margin-top:5px;"><label><input type="checkbox" name="module_socials_feedback_links[' + lang_id + '][' + slide_id + '][is_color]" value="1" /> {{ entry_visible }}</label></div>';
        html += '</td>';
        html += '<td>';
        html += '<label class="control-label">{{ placeholder_title }}</label>';
        html += '<input type="text" name="module_socials_feedback_links[' + lang_id + '][' + slide_id + '][title]" value="" placeholder="{{ placeholder_title }}" class="form-control" /><br />';
        html += '<label class="control-label">{{ placeholder_link }}</label>';
        html += '<input type="text" name="module_socials_feedback_links[' + lang_id + '][' + slide_id + '][link]" value="" placeholder="{{ placeholder_link }}" class="form-control" />';

        html += '</td>';
        html += '<td style="text-align:center"><input type="text" name="module_socials_feedback_links[' + lang_id + '][' + slide_id + '][sort]" value="0" class="form-control" style="width:50px;text-align:center" /></td>';
        html += '<td style="text-align:center"><button type="button" onclick="$(this).parent().parent().remove();" data-toggle="tooltip" title="{{ button_remove }}" class="btn btn-danger"><i class="fa fa-minus-circle"></i></button></td>';
        html += '</tr>';

        block.append(html);
    }

    $('.panel-body .nav').each(function() {
        $(this).find('li:first a').tab('show');
    });
    //--></script>

<style>
    .img-thumbnail img{
        width: 100px;
        height: 100px;
    }
</style>
{{ footer }}